{
  "name": "openclaw-azure-cli",
  "version": "0.1.1",
  "description": "CLI to deploy OpenClaw on Azure AI Foundry — no repo clone needed",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "openclaw-azure": "dist/index.js"
  },
  "files": [
    "dist",
    "infrastructure",
    "openclaw-config"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "dev": "node --loader ts-node/esm src/index.ts",
    "start": "node dist/index.js",
    "release": "semantic-release",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "openclaw",
    "azure",
    "ai-foundry",
    "cli",
    "telegram",
    "gpt-4o"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/hkaanturgut/openclaw-azure-foundry.git",
    "directory": "cli"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/node": "^22.13.10",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "semantic-release": "^25.0.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2",
    "vitest": "^3.2.4"
  }
}
